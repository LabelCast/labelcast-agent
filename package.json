{
  "name": "labelcast-agent",
  "version": "1.0.0",
  "description": "Local print agent — converts Odoo PDF print jobs to ZPL and sends to Zebra printers via TCP",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "odoo",
    "zebra",
    "zpl",
    "label",
    "print",
    "thermal",
    "warehouse"
  ],
  "license": "MIT"
}
