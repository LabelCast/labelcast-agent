# ── HTTP Server ──────────────────────────────────────────────────────
AGENT_PORT=7777
AGENT_HOST=0.0.0.0

# ── Security ─────────────────────────────────────────────────────────
# Odoo sends this in the X-Print-Token header.
# Set a strong random string — e.g. openssl rand -hex 32
API_TOKEN=change-me-to-a-strong-secret

# ── Zebra Printer ─────────────────────────────────────────────────────
# Find your Zebra IP: hold Feed button 2 seconds to print config label
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100
PRINTER_TIMEOUT=10000

# ── Label dimensions ─────────────────────────────────────────────────
# DPI of your Zebra model: 203 (standard) or 300 (high-res)
PRINTER_DPI=203
# Label width in mm
LABEL_WIDTH_MM=100
# Label height in mm — set to 0 to auto-detect from PDF
LABEL_HEIGHT_MM=0

# ── Ghostscript ───────────────────────────────────────────────────────
# Windows: full path to gswin64c.exe if not on PATH
# Download: https://ghostscript.com/releases/gsdnld.html
# GS_PATH=C:\Program Files\gs\gs10.03.1\bin\gswin64c.exe

# ── Queue ─────────────────────────────────────────────────────────────
QUEUE_MAX_HISTORY=200
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000
QUEUE_CONCURRENCY=1

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
