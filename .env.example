# ─── HTTP Server ───────────────────────────────────────────
AGENT_PORT=7777
AGENT_HOST=0.0.0.0

# ─── Security ──────────────────────────────────────────────
# Shared secret - Odoo sends this in the X-Api-Key header
API_KEY=change-me-to-a-strong-secret

# ─── Zebra Printer ─────────────────────────────────────────
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100
PRINTER_TIMEOUT=10000

# ─── Label / Print settings ────────────────────────────────
# DPI of your Zebra printer: 203 or 300
PRINTER_DPI=203
# Label width in mm
LABEL_WIDTH_MM=100
# Label height in mm (0 = auto-detect from PDF)
LABEL_HEIGHT_MM=0

# ─── Conversion ────────────────────────────────────────────
# Path to Ghostscript binary on Windows
# Download: https://ghostscript.com/releases/gsdnld.html
GS_PATH=C:\Program Files\gs\gs10.03.1\bin\gswin64c.exe

# ─── Queue & Storage ───────────────────────────────────────
QUEUE_MAX_HISTORY=200
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
